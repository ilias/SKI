# Test THRICE and ON
# THRICE SUCC ZERO = THREE?
(((EQ ((THRICE SUCC) ZERO)) THREE) S) K)
# ON ADD FST (PAIR TWO THREE) (PAIR ONE FOUR) = ADD TWO ONE = THREE?
# Manual: FST (PAIR TWO THREE) = TWO, FST (PAIR ONE FOUR) = ONE
T1 = (FST ((PAIR TWO) THREE))
T2 = (FST ((PAIR ONE) FOUR))
(((EQ ((ADD T1) T2)) THREE) S) K)
# Now test ON itself: ON ADD FST
ONFST = (((ON ADD) FST) ((PAIR TWO) THREE))
(ONFST ((PAIR ONE) FOUR))

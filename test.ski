# test.ski - Test suite for the SKI interpreter and init.ski library.
#
# Convention: tests that check booleans use  ((b S) K) -> S for TRUE, K for FALSE.
# Load with:  :load test.ski

# ============================================================================
# 0. INTERPRETER SANITY
# ============================================================================

# I combinator: I S = S
(I S)

# K combinator: K S K = S  (selects first)
((K S) K)

# S combinator: S K K S = K S (K S) = S
(((S K) K) S)

# B combinator: B K I S = K (I S) = K S  (partial; not S alone)
# Verify B K I S = K S by checking (B K I S I) = S
((((B K) I) S) I)

# C combinator: C K S I = K I S = I
(((C K) S) I)

# W combinator: W K S = K S S = S
((W K) S)

# Y combinator (lazy): (Y K) I = K (Y K) I = Y K  (K discards I, fixed point of K)
((Y K) I)

# ============================================================================
# 1. PRIMITIVE ALIASES
# ============================================================================

# ID x = I x = x
(ID S)

# CONST x y = K x y = x
((CONST S) K)

# COMPOSE f g x = B f g x = f (g x): B K I S = K (I S) = K S; apply to I -> S
((((COMPOSE K) I) S) I)

# FLIP f x y = C f x y = f y x: C K S I = K I S = I
(((FLIP K) S) I)

# DUP f x = W f x = f x x: W K S = K S S = S
((DUP K) S)

# ============================================================================
# 2. BOOLEANS  (probe: ((b S) K) -> S=TRUE, K=FALSE)
# ============================================================================

# TRUE selects first
((TRUE S) K)

# FALSE selects second
((FALSE S) K)

# NOT TRUE = FALSE
(((NOT TRUE) S) K)

# NOT FALSE = TRUE
(((NOT FALSE) S) K)

# NOT (NOT TRUE) = TRUE
(((NOT (NOT TRUE)) S) K)

# AND TRUE  TRUE  = TRUE
((((AND TRUE) TRUE) S) K)

# AND TRUE  FALSE = FALSE
((((AND TRUE) FALSE) S) K)

# AND FALSE TRUE  = FALSE
((((AND FALSE) TRUE) S) K)

# AND FALSE FALSE = FALSE
((((AND FALSE) FALSE) S) K)

# OR TRUE  TRUE  = TRUE
((((OR TRUE) TRUE) S) K)

# OR TRUE  FALSE = TRUE
((((OR TRUE) FALSE) S) K)

# OR FALSE TRUE  = TRUE
((((OR FALSE) TRUE) S) K)

# OR FALSE FALSE = FALSE
((((OR FALSE) FALSE) S) K)

# XOR TRUE  FALSE = TRUE
((((XOR TRUE) FALSE) S) K)

# XOR FALSE TRUE  = TRUE
((((XOR FALSE) TRUE) S) K)

# XOR TRUE  TRUE  = FALSE
((((XOR TRUE) TRUE) S) K)

# XOR FALSE FALSE = FALSE
((((XOR FALSE) FALSE) S) K)

# NAND TRUE  TRUE  = FALSE
((((NAND TRUE) TRUE) S) K)

# NAND FALSE FALSE = TRUE
((((NAND FALSE) FALSE) S) K)

# NOR FALSE FALSE = TRUE
((((NOR FALSE) FALSE) S) K)

# NOR TRUE  FALSE = FALSE
((((NOR TRUE) FALSE) S) K)

# IF TRUE  S K = S
(((IF TRUE) S) K)

# IF FALSE K S = S  (FALSE selects second arg, which is S)
(((IF FALSE) K) S)

# ============================================================================
# 3. CHURCH PAIRS  (probe: FST/SND return an atom; show it directly)
# ============================================================================

# FST (PAIR S K) = S
(FST ((PAIR S) K))

# SND (PAIR S K) = K
(SND ((PAIR S) K))

# FST (SWAP (PAIR S K)) = K
(FST (SWAP ((PAIR S) K)))

# SND (SWAP (PAIR S K)) = S
(SND (SWAP ((PAIR S) K)))

# nested: FST (SND (PAIR S (PAIR K I))) = K
(FST (SND ((PAIR S) ((PAIR K) I))))

# ============================================================================
# 4. CHURCH NUMERALS - SUCC / PRED
# ============================================================================

# ISZERO ZERO = TRUE
(((ISZERO ZERO) S) K)

# ISZERO ONE  = FALSE
(((ISZERO ONE) S) K)

# ISZERO TWO  = FALSE
(((ISZERO TWO) S) K)

# SUCC ZERO = ONE: EQ (SUCC ZERO) ONE = TRUE
((((EQ (SUCC ZERO)) ONE) S) K)

# SUCC TWO  = THREE
((((EQ (SUCC TWO)) THREE) S) K)

# PRED ONE  = ZERO
((((EQ (PRED ONE)) ZERO) S) K)

# PRED THREE = TWO
((((EQ (PRED THREE)) TWO) S) K)

# PRED ZERO = ZERO  (underflow clamped)
((((EQ (PRED ZERO)) ZERO) S) K)

# ============================================================================
# 5. CHURCH NUMERALS - ARITHMETIC
# ============================================================================

# ADD ZERO TWO = TWO
((((EQ ((ADD ZERO) TWO)) TWO) S) K)

# ADD TWO THREE = FIVE
((((EQ ((ADD TWO) THREE)) FIVE) S) K)

# ADD THREE FOUR = SEVEN
((((EQ ((ADD THREE) FOUR)) SEVEN) S) K)

# MUL ZERO THREE = ZERO
((((EQ ((MUL ZERO) THREE)) ZERO) S) K)

# MUL TWO THREE = SIX
((((EQ ((MUL TWO) THREE)) SIX) S) K)

# MUL THREE THREE = NINE
((((EQ ((MUL THREE) THREE)) NINE) S) K)

# POW TWO ZERO = ONE   (2^0 = 1)
((((EQ ((POW TWO) ZERO)) ONE) S) K)

# POW TWO ONE  = TWO   (2^1 = 2)
((((EQ ((POW TWO) ONE)) TWO) S) K)

# POW TWO TWO  = FOUR  (2^2 = 4)
((((EQ ((POW TWO) TWO)) FOUR) S) K)

# POW THREE TWO = NINE  (3^2 = 9)
((((EQ ((POW THREE) TWO)) NINE) S) K)

# SUB THREE ONE  = TWO
((((EQ ((SUB THREE) ONE)) TWO) S) K)

# SUB TWO TWO   = ZERO
((((EQ ((SUB TWO) TWO)) ZERO) S) K)

# SUB ONE THREE = ZERO  (underflow clamped)
((((EQ ((SUB ONE) THREE)) ZERO) S) K)

# ============================================================================
# 6. CHURCH NUMERALS - COMPARISONS
# ============================================================================

# LEQ TWO THREE = TRUE
((((LEQ TWO) THREE) S) K)

# LEQ THREE THREE = TRUE
((((LEQ THREE) THREE) S) K)

# LEQ FOUR THREE = FALSE
((((LEQ FOUR) THREE) S) K)

# EQ THREE THREE = TRUE
((((EQ THREE) THREE) S) K)

# EQ TWO THREE = FALSE
((((EQ TWO) THREE) S) K)

# GEQ THREE TWO = TRUE
((((GEQ THREE) TWO) S) K)

# GEQ TWO THREE = FALSE
((((GEQ TWO) THREE) S) K)

# GT THREE TWO = TRUE
((((GT THREE) TWO) S) K)

# GT TWO TWO = FALSE
((((GT TWO) TWO) S) K)

# LT TWO THREE = TRUE
((((LT TWO) THREE) S) K)

# LT THREE TWO = FALSE
((((LT THREE) TWO) S) K)

# ============================================================================
# 7. CHURCH LISTS
# ============================================================================

# ISNIL NIL = TRUE
(((ISNIL NIL) S) K)

# ISNIL (CONS S NIL) = FALSE
(((ISNIL ((CONS S) NIL)) S) K)

# HEAD (CONS S NIL) = S
(HEAD ((CONS S) NIL))

# HEAD (CONS K NIL) = K
(HEAD ((CONS K) NIL))

# ISNIL (TAIL (CONS S NIL)) = TRUE  (tail of singleton = NIL)
(((ISNIL (TAIL ((CONS S) NIL))) S) K)

# HEAD (TAIL (CONS S (CONS K NIL))) = K  (second element)
(HEAD (TAIL ((CONS S) ((CONS K) NIL))))

# ============================================================================
# 8. HIGHER-ORDER UTILITIES
# ============================================================================

# TWICE SUCC ONE = THREE  (SUCC(SUCC(ONE)) = 1+2 = 3)
((((EQ ((TWICE SUCC) ONE)) THREE) S) K)

# THRICE SUCC ZERO = THREE
((((EQ ((THRICE SUCC) ZERO)) THREE) S) K)

# ON ADD FST (PAIR TWO THREE) (PAIR ONE FOUR)
# = ADD (FST (PAIR TWO THREE)) (FST (PAIR ONE FOUR))
# = ADD TWO ONE = THREE
((((EQ ((((ON ADD) FST) ((PAIR TWO) THREE)) ((PAIR ONE) FOUR))) THREE) S) K)

# ITERATE = I: ITERATE SUCC ZERO = SUCC ZERO = ONE
((((EQ ((ITERATE SUCC) ZERO)) ONE) S) K)

# ============================================================================
# 9. FIXED POINT (Y combinator)
# ============================================================================

# Y K is a fixed point of K: K (Y K) = Y K  (verifying lazy unrolling)
# (Y K) I -> K (Y K) I -> Y K  (K ignores I, returns Y K)
((Y K) I)

# ============================================================================
# 10. CHURCH NUMERAL UTILITIES
# ============================================================================

# MAX TWO THREE = THREE
((((EQ ((MAX TWO) THREE)) THREE) S) K)

# MAX THREE TWO = THREE  (symmetric)
((((EQ ((MAX THREE) TWO)) THREE) S) K)

# MAX THREE THREE = THREE  (equal inputs)
((((EQ ((MAX THREE) THREE)) THREE) S) K)

# MIN TWO THREE = TWO
((((EQ ((MIN TWO) THREE)) TWO) S) K)

# MIN THREE TWO = TWO  (symmetric)
((((EQ ((MIN THREE) TWO)) TWO) S) K)

# MIN THREE THREE = THREE  (equal inputs)
((((EQ ((MIN THREE) THREE)) THREE) S) K)

# EVEN ZERO = TRUE  (0 is even)
(((EVEN ZERO) S) K)

# EVEN ONE = FALSE  (1 is odd)
(((EVEN ONE) S) K)

# EVEN TWO = TRUE  (2 is even)
(((EVEN TWO) S) K)

# EVEN THREE = FALSE  (3 is odd)
(((EVEN THREE) S) K)

# EVEN FOUR = TRUE  (4 is even)
(((EVEN FOUR) S) K)

# ODD ZERO = FALSE  (0 is not odd)
(((ODD ZERO) S) K)

# ODD ONE = TRUE  (1 is odd)
(((ODD ONE) S) K)

# ODD TWO = FALSE  (2 is not odd)
(((ODD TWO) S) K)

# ODD THREE = TRUE  (3 is odd)
(((ODD THREE) S) K)

# ============================================================================
# 11. CHURCH PAIR UTILITIES
# ============================================================================

# CURRY FST S K = FST (PAIR S K) = S
(((CURRY FST) S) K)

# CURRY SND S K = SND (PAIR S K) = K
(((CURRY SND) S) K)

# UNCURRY K (PAIR S K) = K S K = S
((UNCURRY K) ((PAIR S) K))

# UNCURRY (FLIP K) (PAIR S K) = C K S K = K K S = K
((UNCURRY (FLIP K)) ((PAIR S) K))

# UNCURRY ADD (PAIR TWO THREE) = ADD TWO THREE = FIVE
((((EQ ((UNCURRY ADD) ((PAIR TWO) THREE))) FIVE) S) K)

# ============================================================================
# 12. CHURCH LIST UTILITIES
# ============================================================================

# SECOND (CONS S (CONS K NIL)) = K
(SECOND ((CONS S) ((CONS K) NIL)))

# SECOND (CONS K (CONS S NIL)) = S
(SECOND ((CONS K) ((CONS S) NIL)))

# ISNIL (SINGLETON S) = FALSE  (non-empty list)
(((ISNIL (SINGLETON S)) S) K)

# HEAD (SINGLETON S) = S
(HEAD (SINGLETON S))

# ISNIL (TAIL (SINGLETON S)) = TRUE  (tail is NIL)
(((ISNIL (TAIL (SINGLETON S))) S) K)

# LENGTH NIL = ZERO
((((EQ (LENGTH NIL)) ZERO) S) K)

# LENGTH (SINGLETON S) = ONE
((((EQ (LENGTH (SINGLETON S))) ONE) S) K)

# LENGTH (CONS S (CONS K NIL)) = TWO
((((EQ (LENGTH ((CONS S) ((CONS K) NIL)))) TWO) S) K)

# LENGTH (CONS S (CONS K (CONS I NIL))) = THREE
((((EQ (LENGTH ((CONS S) ((CONS K) ((CONS I) NIL))))) THREE) S) K)

# ============================================================================
# 13. LAMBDA ABSTRACTION  (\x y. body → SKI via bracket abstraction)
# ============================================================================

# \x. x  compiles to  I  (identity)
\x. x

# \x y. x  compiles to  K  (constant / first-projection)
\x y. x

# \x y. y  compiles to  K I  (second-projection = FALSE)
\x y. y

# \f x. (f x)  has a free tail: eta-reduces to  I
\f x. (f x)

# Church 2 written as lambda: \f x. (f (f x))  = (S B) I
LAMBDA2 = \f x. (f (f x))
((((EQ LAMBDA2) TWO) S) K)

# Church 3 written as lambda: \f x. (f (f (f x)))
LAMBDA3 = \f x. (f (f (f x)))
((((EQ LAMBDA3) THREE) S) K)

# Lambda NOT: \b. \x y. (b y x)  should equal NOT (= C)
LNOT = \b x y. (b y x)
(((LNOT TRUE) S) K)    # LNOT TRUE = FALSE → K
(((LNOT FALSE) S) K)   # LNOT FALSE = TRUE → S

# Lambda AND: \p q. (p q FALSE)
LAND = \p q. (p q FALSE)
((((LAND TRUE) TRUE) S) K)    # TRUE
((((LAND TRUE) FALSE) S) K)   # FALSE
((((LAND FALSE) TRUE) S) K)   # FALSE

# Lambda K (const): \x y. x
LK = \x y. x
((((EQ LK) K) S) K)

# ============================================================================
# 14. PARAMETERIZED DEFINITIONS  (Name x y = body  is sugar for  Name = \x y. body)
# ============================================================================

# Identity: MYID x = x  →  I
MYID x = x
MYID

# Constant: MYCONST x y = x  →  K
MYCONST x y = x
((MYCONST S) K)        # → S  (K selects first)

# Composition: MYCOMPOSE f g x = (f (g x))  →  B
MYCOMPOSE f g x = (f (g x))
# MYCOMPOSE SUCC (ADD ONE) TWO = SUCC(ADD ONE TWO) = SUCC THREE = FOUR
((((EQ (((MYCOMPOSE SUCC) (ADD ONE)) TWO)) FOUR) S) K)

# Flip: MYFLIP f x y = (f y x)  →  C
MYFLIP f x y = (f y x)
(((MYFLIP K) S) I)     # MYFLIP K S I = K I S = I

# Two-arg addition shorthand
MYADD x y = (ADD x y)
((((EQ ((MYADD TWO) THREE)) FIVE) S) K)

# Recursive factorial via Y:  FACTF rec n = IF (ISZERO n) ONE (MUL n (rec (PRED n)))
# Written using parameterized definition for the step function, wrapped with Y:
FACTF rec n = (ISZERO n ONE ((MUL n) (rec (PRED n))))
FACT = (Y FACTF)
((((EQ (FACT ZERO)) ONE) S) K)   # 0! = 1
((((EQ (FACT ONE))  ONE) S) K)   # 1! = 1
((((EQ (FACT TWO))  TWO) S) K)   # 2! = 2
((((EQ (FACT THREE)) SIX) S) K)  # 3! = 6
((((EQ (FACT FOUR)) ((MUL SIX) FOUR)) S) K)  # 4! = 24 = MUL 6 4

# ============================================================================
# 15. INTEGER LITERALS  (n in source  →  Church numeral at parse time)
# ============================================================================

# Literal 0 = ZERO
((((EQ 0) ZERO) S) K)

# Literal 1 = ONE
((((EQ 1) ONE) S) K)

# Literal 2 = TWO
((((EQ 2) TWO) S) K)

# Literal 5 = FIVE
((((EQ 5) FIVE) S) K)

# Literals in arithmetic: ADD 2 3 = FIVE
((((EQ ((ADD 2) 3)) FIVE) S) K)

# Literals in comparisons: LEQ 3 5 = TRUE
(((LEQ 3) 5) S)    # should reduce to S (TRUE applied to S K → S)
(((LEQ 3) 5) K)    # → K for second arg

# MUL 3 4 = 12
((((EQ ((MUL 3) 4)) ((MUL THREE) FOUR)) S) K)

# POW 2 4 = 16  (2^8=256 is too expensive for EQ; use smaller exponent)
((((EQ ((POW 2) 4)) ((POW TWO) FOUR)) S) K)

# Literal in parameterized def body: successor of 4 = 5
((((EQ (SUCC 4)) 5) S) K)

# Zero as Church numeral: ISZERO 0 = TRUE
(((ISZERO 0) S) K)

# Non-zero literal: ISZERO 1 = FALSE
(((ISZERO 1) S) K)

# ============================================================================
# 16. LET-EXPRESSIONS  (let x = e1 in e2  →  (\x. e2) e1)
# ============================================================================

# Trivial binding: let s = S in s → S
let s = S in s

# K binding used in body: let k = K in (k S K) → S  (K selects first)
let k = K in ((k S) K)

# Boolean probe inside the body: SUCC TWO = THREE
let f = SUCC in ((((EQ (f TWO)) THREE) S) K)

# Parameterized let (sugar for let sq = \x. ...): sq THREE = NINE
let sq x = ((MUL x) x) in ((((EQ (sq THREE)) NINE) S) K)

# Nested lets: TWO + THREE = FIVE  (no outer parens — parser handles nested let directly)
let x = TWO in let y = THREE in ((((EQ ((ADD x) y)) FIVE) S) K)

# Let with lambda body: double THREE = SIX
let double = \n. ((MUL 2) n) in ((((EQ (double THREE)) SIX) S) K)

# ============================================================================
# 17. IMPORT DIRECTIVE  (import <path> inside .ski files resolves relative to importer)
# ============================================================================

import testlib.ski

# DOUBLE_NAT (= MUL 2) THREE = SIX
((((EQ (DOUBLE_NAT THREE)) SIX) S) K)

# TRIPLE_NAT (= MUL 3) TWO = SIX
((((EQ (TRIPLE_NAT TWO)) SIX) S) K)

# Imported definitions compose with init.ski library: SUCC (DOUBLE_NAT ONE) = THREE
((((EQ (SUCC (DOUBLE_NAT ONE))) THREE) S) K)

# Imported + parameterized: DOUBLE_NAT applied via let binding
let dn = DOUBLE_NAT in ((((EQ (dn FOUR)) EIGHT) S) K)

# ============================================================================
# 18. DIV AND MOD
# ============================================================================

# DIV 6 2 = 3  (exact)
((((EQ ((DIV 6) 2)) THREE) S) K)

# DIV 7 2 = 3  (floor: 7/2 = 3.5 → 3)
((((EQ ((DIV 7) 2)) THREE) S) K)

# DIV 0 5 = 0  (zero numerator)
((((EQ ((DIV 0) 5)) ZERO) S) K)

# DIV 5 5 = 1  (equal numerator and denominator)
((((EQ ((DIV 5) 5)) ONE) S) K)

# DIV 10 3 = 3  (floor(10/3) = 3)
((((EQ ((DIV 10) 3)) THREE) S) K)

# DIV 1 5 = 0  (numerator < denominator)
((((EQ ((DIV 1) 5)) ZERO) S) K)

# MOD 7 3 = 1  (7 = 2*3 + 1)
((((EQ ((MOD 7) 3)) ONE) S) K)

# MOD 6 2 = 0  (exact)
((((EQ ((MOD 6) 2)) ZERO) S) K)

# MOD 5 5 = 0  (equal args)
((((EQ ((MOD 5) 5)) ZERO) S) K)

# MOD 3 5 = 3  (numerator < denominator returns numerator unchanged)
((((EQ ((MOD 3) 5)) THREE) S) K)

# MOD 10 3 = 1  (10 = 3*3 + 1)
((((EQ ((MOD 10) 3)) ONE) S) K)

# Euclidean identity: DIV m n * n + MOD m n = m
# 7 = DIV 7 3 * 3 + MOD 7 3 = 2*3 + 1 = 7
((((EQ ((ADD ((MUL ((DIV 7) 3)) 3)) ((MOD 7) 3))) 7) S) K)

# 10 = DIV 10 4 * 4 + MOD 10 4 = 2*4 + 2 = 10
((((EQ ((ADD ((MUL ((DIV 10) 4)) 4)) ((MOD 10) 4))) 10) S) K)

# ============================================================================
# 19. M AND T COMBINATORS
# ============================================================================

# M I = I I = I  (self-application of identity)
(M I)

# M K  →  K K  (self-application of K)
(M K)

# T S K = K S  (reverse-apply: gives K applied to S)
# Verify T S K applied to I = (K S) I = S
(((T S) K) I)

# T ONE SUCC = SUCC ONE = TWO
((((EQ ((T ONE) SUCC)) TWO) S) K)

# T TWO SUCC = SUCC TWO = THREE
((((EQ ((T TWO) SUCC)) THREE) S) K)

# MOCK = M  (alias)
(MOCK I)

# THRUSH = T  (alias)
((((EQ ((THRUSH TWO) SUCC)) THREE) S) K)

# ============================================================================
# 20. LETREC EXPRESSIONS  (letrec f x = body in e  →  (\f. e) (Y (\f x. body)))
# ============================================================================

# Factorial via letrec: 5! = 120  [auto-hint verifies: Nat 120]
letrec fact n = ((ISZERO n) ONE ((MUL n) (fact (PRED n)))) in (fact FIVE)

# Factorial using EQ — letrec in argument position requires no extra outer parens
((((EQ letrec fact2 n = ((ISZERO n) ONE ((MUL n) (fact2 (PRED n)))) in (fact2 FIVE)) ((MUL ((MUL ((MUL ((MUL 1) 2)) 3)) 4)) 5)) S) K)

# Triangular numbers: tri 4 = 0+1+2+3+4 = 10  [hint: Nat 10]
letrec tri n = ((ISZERO n) ZERO ((ADD n) (tri (PRED n)))) in (tri FOUR)

# Fibonacci: fib 6 = 8  [hint: Nat 8] (all on one line for .ski file)
letrec fib n = (((ISZERO n) ZERO) (((ISZERO (PRED n)) ONE) ((ADD (fib (PRED n))) (fib (PRED (PRED n)))))) in (fib SIX)

# Identity-like recursion: count n returns n unchanged  [hint: Nat 3]
letrec count n = ((ISZERO n) ZERO (SUCC (count (PRED n)))) in (count THREE)

# Nested let + letrec: 3^2 = 9  [hint: Nat 9]
let base = THREE in letrec pow n = ((ISZERO n) ONE ((MUL base) (pow (PRED n)))) in (pow TWO)

# ============================================================================
# 21. RECURSIVE NUMERIC FUNCTIONS  (GCD, LCM, TRI, SQ, CUBE, DIST)
# ============================================================================

# --- GCD (greatest common divisor, Euclidean algorithm) ---

# GCD n n = n  (equal args)
((((EQ ((GCD SIX) SIX)) SIX) S) K)

# GCD 6 4 = 2
((((EQ ((GCD SIX) FOUR)) TWO) S) K)

# GCD 10 6 = 2
((((EQ ((GCD TEN) SIX)) TWO) S) K)

# GCD 9 6 = 3
((((EQ ((GCD NINE) SIX)) THREE) S) K)

# GCD 7 5 = 1  (coprime)
((((EQ ((GCD SEVEN) FIVE)) ONE) S) K)

# GCD n 0 = n  (zero is identity)
((((EQ ((GCD FIVE) ZERO)) FIVE) S) K)

# GCD commutes: GCD 4 6 = GCD 6 4 = 2
((((EQ ((GCD FOUR) SIX)) ((GCD SIX) FOUR)) S) K)

# --- LCM (least common multiple) ---

# LCM 4 6 = 12
((((EQ ((LCM FOUR) SIX)) ((MUL TWO) SIX)) S) K)

# LCM 3 5 = 15  (coprime: lcm = product)
((((EQ ((LCM THREE) FIVE)) ((MUL THREE) FIVE)) S) K)

# LCM 6 4 = 12  (commutative)
((((EQ ((LCM SIX) FOUR)) ((LCM FOUR) SIX)) S) K)

# LCM 1 n = n
((((EQ ((LCM ONE) SEVEN)) SEVEN) S) K)

# --- TRI (triangular numbers: TRI n = 1+2+...+n) ---

# TRI 0 = 0
((((EQ (TRI ZERO)) ZERO) S) K)

# TRI 1 = 1
((((EQ (TRI ONE)) ONE) S) K)

# TRI 3 = 6
((((EQ (TRI THREE)) SIX) S) K)

# TRI 4 = 10
((((EQ (TRI FOUR)) TEN) S) K)

# TRI 5 = 15
((((EQ (TRI FIVE)) ((ADD TEN) FIVE)) S) K)

# --- SQ (square: SQ n = n*n) ---

# SQ 0 = 0
((((EQ (SQ ZERO)) ZERO) S) K)

# SQ 1 = 1
((((EQ (SQ ONE)) ONE) S) K)

# SQ 3 = 9
((((EQ (SQ THREE)) NINE) S) K)

# SQ 4 = 16
((((EQ (SQ FOUR)) ((MUL FOUR) FOUR)) S) K)

# SQ n = MUL n n
((((EQ (SQ FIVE)) ((MUL FIVE) FIVE)) S) K)

# --- CUBE (cube: CUBE n = n*n*n) ---

# CUBE 0 = 0
((((EQ (CUBE ZERO)) ZERO) S) K)

# CUBE 1 = 1
((((EQ (CUBE ONE)) ONE) S) K)

# CUBE 2 = 8
((((EQ (CUBE TWO)) EIGHT) S) K)

# CUBE 3 = 27
((((EQ (CUBE THREE)) ((MUL NINE) THREE)) S) K)

# CUBE n = MUL (SQ n) n
((((EQ (CUBE FOUR)) ((MUL (SQ FOUR)) FOUR)) S) K)

# --- DIST (absolute difference: DIST m n = |m - n|) ---

# DIST n n = 0
((((EQ ((DIST FOUR) FOUR)) ZERO) S) K)

# DIST 5 3 = 2
((((EQ ((DIST FIVE) THREE)) TWO) S) K)

# DIST 3 5 = 2  (symmetric)
((((EQ ((DIST THREE) FIVE)) TWO) S) K)

# DIST commutes: DIST m n = DIST n m
((((EQ ((DIST SEVEN) TWO)) ((DIST TWO) SEVEN)) S) K)

# DIST n 0 = n
((((EQ ((DIST SIX) ZERO)) SIX) S) K)

# ============================================================================
# 22. CHURCH LIST HIGHER-ORDER FUNCTIONS
#     MAP / FOLDR / FOLDL / FILTER / APPEND / REVERSE / ZIP
# ============================================================================

# Helper lists used throughout:
#   L123 = [ONE, TWO, THREE]
#   L12  = [ONE, TWO]
#   L34  = [THREE, FOUR]
#   L013 = [ZERO, ONE, TWO, THREE]

# ----- MAP -----

# MAP SUCC [ONE, TWO, THREE]: length = 3
((((EQ (LENGTH ((MAP SUCC) ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL)))))) THREE) S) K)

# MAP SUCC [ONE, TWO]: HEAD = TWO
((((EQ (HEAD ((MAP SUCC) ((CONS ONE) ((CONS TWO) NIL))))) TWO) S) K)

# MAP SUCC [ONE, TWO]: HEAD TAIL = THREE
((((EQ (HEAD (TAIL ((MAP SUCC) ((CONS ONE) ((CONS TWO) NIL)))))) THREE) S) K)

# MAP over NIL = NIL  (length 0)
((((EQ (LENGTH ((MAP SUCC) NIL))) ZERO) S) K)

# ----- FOLDR -----

# FOLDR ADD ZERO [ONE, TWO, THREE] = SIX  (1+2+3)
((((EQ (((FOLDR ADD) ZERO) ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL))))) SIX) S) K)

# FOLDR ADD ZERO NIL = ZERO  (base case)
((((EQ (((FOLDR ADD) ZERO) NIL)) ZERO) S) K)

# FOLDR MUL ONE [TWO, THREE] = SIX  (2*3)
((((EQ (((FOLDR MUL) ONE) ((CONS TWO) ((CONS THREE) NIL)))) SIX) S) K)

# ----- FOLDL -----

# FOLDL ADD ZERO [ONE, TWO, THREE] = SIX
((((EQ (((FOLDL ADD) ZERO) ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL))))) SIX) S) K)

# FOLDL ADD ZERO NIL = ZERO  (base case)
((((EQ (((FOLDL ADD) ZERO) NIL)) ZERO) S) K)

# FOLDL (FLIP CONS) NIL [ONE, TWO, THREE]: HEAD = THREE  (left-fold reversal)
((((EQ (HEAD (((FOLDL (FLIP CONS)) NIL) ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL)))))) THREE) S) K)

# ----- FILTER -----

# FILTER EVEN [ZERO, ONE, TWO, THREE] = [ZERO, TWO]: length 2
((((EQ (LENGTH ((FILTER EVEN) ((CONS ZERO) ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL))))))) TWO) S) K)

# HEAD of even-filtered list = ZERO
((((EQ (HEAD ((FILTER EVEN) ((CONS ZERO) ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL))))))) ZERO) S) K)

# HEAD TAIL of even-filtered list = TWO
((((EQ (HEAD (TAIL ((FILTER EVEN) ((CONS ZERO) ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL)))))))) TWO) S) K)

# FILTER ODD [ZERO, ONE, TWO] = [ONE]: length 1
((((EQ (LENGTH ((FILTER ODD) ((CONS ZERO) ((CONS ONE) ((CONS TWO) NIL)))))) ONE) S) K)

# FILTER on NIL = NIL
((((EQ (LENGTH ((FILTER EVEN) NIL))) ZERO) S) K)

# ----- APPEND -----

# APPEND [ONE, TWO] [THREE]: length 3
((((EQ (LENGTH ((APPEND ((CONS ONE) ((CONS TWO) NIL))) ((CONS THREE) NIL)))) THREE) S) K)

# HEAD of appended list = ONE
((((EQ (HEAD ((APPEND ((CONS ONE) ((CONS TWO) NIL))) ((CONS THREE) NIL)))) ONE) S) K)

# HEAD TAIL TAIL of appended list = THREE
((((EQ (HEAD (TAIL (TAIL ((APPEND ((CONS ONE) ((CONS TWO) NIL))) ((CONS THREE) NIL)))))) THREE) S) K)

# APPEND NIL l = l  (left identity: length preserved)
((((EQ (LENGTH ((APPEND NIL) ((CONS ONE) ((CONS TWO) NIL))))) TWO) S) K)

# APPEND l NIL = l  (right identity: length preserved)
((((EQ (LENGTH ((APPEND ((CONS ONE) ((CONS TWO) NIL))) NIL))) TWO) S) K)

# ----- REVERSE -----

# REVERSE [ONE, TWO, THREE]: HEAD = THREE
((((EQ (HEAD (REVERSE ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL)))))) THREE) S) K)

# REVERSE [ONE, TWO, THREE]: HEAD TAIL = TWO
((((EQ (HEAD (TAIL (REVERSE ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL))))))) TWO) S) K)

# REVERSE preserves length
((((EQ (LENGTH (REVERSE ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL)))))) THREE) S) K)

# REVERSE (REVERSE l) = l: HEAD = ONE
((((EQ (HEAD (REVERSE (REVERSE ((CONS ONE) ((CONS TWO) ((CONS THREE) NIL))))))) ONE) S) K)

# ----- ZIP -----

# ZIP [ONE, TWO] [THREE, FOUR]: length 2
((((EQ (LENGTH ((ZIP ((CONS ONE) ((CONS TWO) NIL))) ((CONS THREE) ((CONS FOUR) NIL))))) TWO) S) K)

# FST of HEAD of zipped list = ONE
((((EQ (FST (HEAD ((ZIP ((CONS ONE) ((CONS TWO) NIL))) ((CONS THREE) ((CONS FOUR) NIL)))))) ONE) S) K)

# SND of HEAD of zipped list = THREE
((((EQ (SND (HEAD ((ZIP ((CONS ONE) ((CONS TWO) NIL))) ((CONS THREE) ((CONS FOUR) NIL)))))) THREE) S) K)

# ZIP stops at the shorter list: ZIP [ONE] [TWO, THREE] = length 1
((((EQ (LENGTH ((ZIP ((CONS ONE) NIL)) ((CONS TWO) ((CONS THREE) NIL))))) ONE) S) K)

# ZIP NIL l = NIL
((((EQ (LENGTH ((ZIP NIL) ((CONS ONE) NIL)))) ZERO) S) K)
